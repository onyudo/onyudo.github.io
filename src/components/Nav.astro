---
import siteConfig from '../data/site-config';

const navLinks = siteConfig.headerNavLinks || [];
---

<div class="nav-container">
    {
        navLinks.length > 0 && (
            <div class="nav-links">
                {navLinks.map((link) => (
                    <a href={link.href}>
                        {link.text}
                    </a>
                ))}
            </div>
        )
    }
</div>