---
import siteConfig from '../data/site-config';

const socialLinks = siteConfig.socialLinks || [];
---

<footer>
    {
            socialLinks.length > 0 && (
                <div class="footerNav">
                    {socialLinks.map((link) => (
                        <a
                            href={link.href}
                            target="_blank"
                            rel="noopener noreferer"
                        >
                            {link.text}
                        </a>
                    ))}
                </div>
            )
    }
        <p>
            &copy; {new Date().getFullYear()}&nbsp;<a href="/">{siteConfig.title}</a>. All rights reserved.
        </p>
    </div>
</footer>